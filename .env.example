# Local development — copy to .env and fill in (optional; desktop app uses config/firebase_config.py)

# API (desktop client)
API_BASE_URL=http://127.0.0.1:8000

# Firebase (desktop sign-in + API token verification)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Hosted API on Render — set these in the Render dashboard, not in git
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
FIREBASE_SERVICE_ACCOUNT_JSON=
